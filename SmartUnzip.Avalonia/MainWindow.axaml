<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SmartUnzip.Avalonia.Views"
        xmlns:viewModels="clr-namespace:SmartUnzip.Avalonia.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SmartUnzip.Avalonia.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="SmartUnzip.Avalonia">

    <TabControl
        Name="tab"
        Grid.Row="1"
        Margin="8"
        Padding="20,0,0,0"
        HorizontalAlignment="Stretch"
        TabStripPlacement="Left"
        Theme="{DynamicResource NavigationTab}"
        >
        <TabItem Header="主页">
            <views:HomeView />
        </TabItem>
        <TabItem Header="密码管理">
            <views:PasswordManagerView />
        </TabItem>
    </TabControl>

</Window>